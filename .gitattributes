# Normalise line endings to LF in the repo (this app is cross-platform).
* text=auto eol=lf

# Keep shell scripts LF even on Windows checkouts.
*.sh text eol=lf

# Binary assets — never diff or eol-normalise.
*.png binary
*.ico binary
*.icns binary
*.woff binary
*.woff2 binary
*.ttf binary

# Generated files — collapse in diffs and exclude from language stats (GitHub linguist).
src/bindings/** linguist-generated=true
package-lock.json linguist-generated=true
src-tauri/Cargo.lock linguist-generated=true
docs/adr/manifest.json linguist-generated=true
docs/adr/README.md linguist-generated=true
docs/adr/current/README.md linguist-generated=true
.claude/rules/INDEX.md linguist-generated=true
