{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Vidforge",
  "mainBinaryName": "vidforge",
  "version": "../package.json",
  "identifier": "com.kaoszwerg.vidforge",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Vidforge",
        "width": 1280,
        "height": 832,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "maximizable": true,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "backgroundColor": [0, 0, 0, 0]
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: http://asset.localhost data:; style-src 'self' 'unsafe-inline'; font-src 'self' data:; script-src 'self'; connect-src 'self' ipc: http://ipc.localhost; media-src 'self' blob: asset: http://asset.localhost",
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/cache/**"]
      }
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "app", "dmg", "deb", "rpm", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "14.4"
    },
    "windows": {
      "nsis": {
        "template": "windows/installer.nsi"
      }
    }
  }
}
