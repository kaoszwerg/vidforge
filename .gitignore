# --- Rust / Tauri backend ---
/src-tauri/target/
# Tauri-generated ACL / capability schemas — regenerated on every build.
/src-tauri/gen/schemas/
**/*.rs.bk
*.pdb

# --- Node / frontend ---
node_modules/
dist/
dist-ssr/
*.local
.vite/
# TypeScript incremental build cache (regenerated by `tsc -b`).
*.tsbuildinfo

# --- Test / coverage ---
coverage/
/src-tauri/coverage/
*.profraw
lcov.info

# --- Local app data (never commit) ---
settings.json.tmp

# --- OS / editor noise ---
.DS_Store
Thumbs.db
*.swp
.idea/

# --- Secrets / env (never commit) ---
.env
.env.*
!.env.example
.envrc.local
# Signing material must never be committed.
*.p12
*.cer
*.certSigningRequest
*.mobileprovision

# --- Local Claude Code overrides (shared settings.json IS committed) ---
.claude/settings.local.json
.claude/memory/*.bak-*
.claude/scheduled_tasks.lock
.claude/scheduled_tasks.json

# NOTE: Cargo.lock and package-lock.json ARE committed (application, reproducible builds).
